<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

    <form action="/new-category" method="POST">
        <div class="form-group">
            <label for="c_name">Category Name</label>
            <input
                type="text"
                id="c_name"
                name="c_name"
                maxlength="100"
                required
            />
        </div>

        <button type="submit">Create Category</button>
    </form>
</main>
<%- include('partials/footer') %>